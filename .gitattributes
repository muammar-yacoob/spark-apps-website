# Enforce LF line endings for all text files
* text=auto eol=lf

# Explicitly LF for shell/config files
*.sh text eol=lf
*.env text eol=lf
*.env.example text eol=lf
*.md text eol=lf
*.json text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf

# Owner-only assets  excluded from git archive exports (repo distribution)
public/animations/ export-ignore
public/testimonials/avatars/ export-ignore

# Binary files  no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.gz binary
