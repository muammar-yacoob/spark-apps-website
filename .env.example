# SparkStack env vars. Copy to .env.local and fill in.

# ── Required ──────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"        # REQUIRED in production: your deployed domain (e.g. https://yourdomain.com)

# ── Optional ──────────────────────────────────────────────────────
# ALLOWED_EMAILS="you@gmail.com"           # Comma-separated whitelist; leave empty to allow all authenticated users
# AUTH_SECRET=""                            # Auto-generated by NextAuth if not set
# NEXT_PUBLIC_SUPPORT_EMAIL=""              # Shown in error pages and footer; defaults to hello@<your-domain>

# Contact form email (omit to log submissions only)
# BOTTLED_EMAIL_API_KEY=""
# CONTACT_FROM_EMAIL=""                     # Sender + recipient address for contact form

# Chat widget (loaded in production only)
# NEXT_PUBLIC_CHAT_WIDGET_URL=""            # e.g. https://sparkbrain.app/chat.js
